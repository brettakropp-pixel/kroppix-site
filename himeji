<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Himeji Castle | kroppix</title>
  <style>
    :root {
      --bg: #f7f4ee;
      --text: #1d1d1b;
      --muted: #6b675f;
      --line: #d9d2c7;
      --card: #efe9de;
      --max: 1180px;
      --shadow: 0 6px 18px rgba(0,0,0,0.12);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(247, 244, 238, 0.96);
      backdrop-filter: blur(6px);
      border-bottom: 1px solid var(--line);
    }

    .nav {
      max-width: var(--max);
      margin: 0 auto;
      padding: 18px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }

    .brand {
      font-size: 1.2rem;
      font-weight: bold;
      letter-spacing: 0.03em;
    }

    .nav-links {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 0.95rem;
      color: var(--muted);
    }

    main {
      max-width: var(--max);
      margin: 0 auto;
      padding: 28px 24px 64px;
    }

    .hero {
      margin-bottom: 48px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.25fr 1fr;
      gap: 28px;
      align-items: end;
    }

    .hero-image {
      background: white;
      padding: 10px;
      box-shadow: var(--shadow);
    }

    .hero-copy h1 {
      margin: 0 0 10px;
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1.05;
      font-weight: normal;
    }

    .hero-copy p {
      margin: 0 0 10px;
      color: var(--muted);
      max-width: 40ch;
    }

    .section {
      margin-top: 56px;
    }

    .section-heading {
      margin-bottom: 22px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
    }

    .section-heading h2 {
      margin: 0 0 4px;
      font-size: 1.7rem;
      font-weight: normal;
    }

    .section-heading p {
      margin: 0;
      color: var(--muted);
      font-size: 0.98rem;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 18px;
    }

    .card {
      grid-column: span 4;
      background: white;
      padding: 10px;
      box-shadow: var(--shadow);
      cursor: pointer;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(0,0,0,0.14);
    }

    .card img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      background: #ddd;
    }

    .card.tall img {
      height: 420px;
    }

    .card.wide {
      grid-column: span 6;
    }

    .card.small {
      grid-column: span 3;
    }

    .caption {
      padding: 10px 4px 2px;
    }

    .caption-title {
      display: block;
      font-size: 0.98rem;
    }

    .caption-sub {
      display: block;
      font-size: 0.88rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .sequence {
      margin-top: 18px;
      background: var(--card);
      border: 1px solid var(--line);
      padding: 18px;
    }

    .sequence h3 {
      margin: 0 0 6px;
      font-size: 1.15rem;
      font-weight: normal;
    }

    .sequence p {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .sequence-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .sequence .card {
      grid-column: auto;
      padding: 8px;
      margin: 0;
    }

    .sequence .card img {
      height: 360px;
      object-fit: cover;
    }

    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.88);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
      z-index: 100;
    }

    .lightbox.open {
      display: flex;
    }

    .lightbox-inner {
      max-width: 1100px;
      width: 100%;
    }

    .lightbox img {
      max-height: 80vh;
      margin: 0 auto;
      box-shadow: 0 12px 28px rgba(0,0,0,0.35);
    }

    .lightbox-caption {
      color: white;
      text-align: center;
      margin-top: 14px;
      font-size: 0.95rem;
    }

    .lightbox-close {
      position: absolute;
      top: 18px;
      right: 22px;
      border: 0;
      background: transparent;
      color: white;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
    }

    footer {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 24px 50px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    @media (max-width: 920px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      .card,
      .card.wide,
      .card.small {
        grid-column: span 6;
      }

      .sequence-grid {
        grid-template-columns: 1fr;
      }

      .sequence .card img,
      .card.tall img {
        height: 320px;
      }
    }

    @media (max-width: 620px) {
      main {
        padding: 20px 16px 48px;
      }

      .nav {
        padding: 14px 16px;
      }

      .card,
      .card.wide,
      .card.small {
        grid-column: span 12;
      }

      .card img,
      .card.tall img,
      .sequence .card img {
        height: auto;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="nav">
      <a href="index.html" class="brand">kroppix</a>
      <nav class="nav-links">
        <a href="japan.html">Japan</a>
        <a href="arashiyama.html">Arashiyama</a>
        <a href="tennoji.html">Tennoji</a>
        <a href="himeji.html">Himeji</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-image">
          <img
            src="https://images.kroppix.com/japan/himeji/himeji-cherry-blossom.jpg"
            alt="Himeji Castle framed by cherry blossom"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="hero-copy">
          <h1>Himeji Castle</h1>
          <p>A return to Himeji across two seasons — winter architecture and spring blossom.</p>
          <p>This album moves from broad castle views into rooflines, details, gardens, and the atmosphere around the grounds.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <h2>Winter</h2>
        <p>Quiet, pale light and strong architectural lines.</p>
      </div>

      <div class="gallery-grid">
        <figure class="card wide" data-full="https://images.kroppix.com/japan/himeji/himeji-castle-winter.jpg" data-caption="Himeji Castle in winter">
          <img src="https://images.kroppix.com/japan/himeji/himeji-castle-winter.jpg" alt="Himeji Castle in winter" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Winter view</span>
            <span class="caption-sub">Main keep in soft winter light</span>
          </figcaption>
        </figure>

        <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-building-detail.jpg" data-caption="Wall and roof detail at Himeji Castle">
          <img src="https://images.kroppix.com/japan/himeji/himeji-building-detail.jpg" alt="Wall and roof detail at Himeji Castle" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Building detail</span>
            <span class="caption-sub">Texture, stone and tile</span>
          </figcaption>
        </figure>

        <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-perspective.jpg" data-caption="Layered rooftops at Himeji Castle">
          <img src="https://images.kroppix.com/japan/himeji/himeji-perspective.jpg" alt="Layered rooftops at Himeji Castle" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Perspective</span>
            <span class="caption-sub">Rooflines stacking into the frame</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <h2>Roof study sequence</h2>
        <p>A three-image sequence moving from the wider form into ornament and detail.</p>
      </div>

      <div class="sequence">
        <h3>From form to detail</h3>
        <p>Read left to right: establish, move closer, finish on the cresting detail.</p>

        <div class="sequence-grid">
          <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-roof-1.jpg" data-caption="Himeji roof study I">
            <img src="https://images.kroppix.com/japan/himeji/himeji-roof-1.jpg" alt="Himeji roof study one" loading="lazy" decoding="async" />
            <figcaption class="caption">
              <span class="caption-title">Roof study I</span>
              <span class="caption-sub">Establishing view</span>
            </figcaption>
          </figure>

          <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-roof-2.jpg" data-caption="Himeji roof study II">
            <img src="https://images.kroppix.com/japan/himeji/himeji-roof-2.jpg" alt="Himeji roof study two" loading="lazy" decoding="async" />
            <figcaption class="caption">
              <span class="caption-title">Roof study II</span>
              <span class="caption-sub">Closer into line and form</span>
            </figcaption>
          </figure>

          <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-roof-3.jpg" data-caption="Himeji roof study III">
            <img src="https://images.kroppix.com/japan/himeji/himeji-roof-3.jpg" alt="Himeji roof study three" loading="lazy" decoding="async" />
            <figcaption class="caption">
              <span class="caption-title">Roof study III</span>
              <span class="caption-sub">Final detail</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <h2>Spring blossom</h2>
        <p>The same place shifting into colour, people and blossom season.</p>
      </div>

      <div class="gallery-grid">
        <figure class="card wide" data-full="https://images.kroppix.com/japan/himeji/himeji-cherry-blossom.jpg" data-caption="Himeji Castle in cherry blossom season">
          <img src="https://images.kroppix.com/japan/himeji/himeji-cherry-blossom.jpg" alt="Himeji Castle in cherry blossom season" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Cherry blossom</span>
            <span class="caption-sub">Castle framed by spring bloom</span>
          </figcaption>
        </figure>

        <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-cherry-blossom-crowd.jpg" data-caption="Crowds under cherry blossom at Himeji">
          <img src="https://images.kroppix.com/japan/himeji/himeji-cherry-blossom-crowd.jpg" alt="Crowds under cherry blossom at Himeji" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Blossom crowd</span>
            <span class="caption-sub">Seasonal energy around the grounds</span>
          </figcaption>
        </figure>

        <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-gardens-mika.jpg" data-caption="Mika in the gardens at Himeji">
          <img src="https://images.kroppix.com/japan/himeji/himeji-gardens-mika.jpg" alt="Mika in the gardens at Himeji" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Gardens</span>
            <span class="caption-sub">A quieter human moment</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <h2>Details & atmosphere</h2>
        <p>Small observations around the castle grounds.</p>
      </div>

      <div class="gallery-grid">
        <figure class="card small" data-full="https://images.kroppix.com/japan/himeji/himeji-bird.jpg" data-caption="Bird perched on rock at Himeji">
          <img src="https://images.kroppix.com/japan/himeji/himeji-bird.jpg" alt="Bird perched on rock at Himeji" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Bird</span>
            <span class="caption-sub">A small pause in the scene</span>
          </figcaption>
        </figure>

        <figure class="card tall" data-full="https://images.kroppix.com/japan/himeji/himeji-hinge-detail.jpg" data-caption="Wooden door hinge detail at Himeji">
          <img src="https://images.kroppix.com/japan/himeji/himeji-hinge-detail.jpg" alt="Wooden door hinge detail at Himeji" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Hinge detail</span>
            <span class="caption-sub">Weathered wood and ironwork</span>
          </figcaption>
        </figure>

        <figure class="card small" data-full="https://images.kroppix.com/japan/himeji/himeji-koi.jpg" data-caption="Koi at Himeji">
          <img src="https://images.kroppix.com/japan/himeji/himeji-koi.jpg" alt="Koi at Himeji" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Koi</span>
            <span class="caption-sub">Soft colour in the water</span>
          </figcaption>
        </figure>

        <figure class="card" data-full="https://images.kroppix.com/japan/himeji/himeji-roof-lines.jpg" data-caption="Roof lines at Himeji Castle">
          <img src="https://images.kroppix.com/japan/himeji/himeji-roof-lines.jpg" alt="Roof lines at Himeji Castle" loading="lazy" decoding="async" />
          <figcaption class="caption">
            <span class="caption-title">Roof lines</span>
            <span class="caption-sub">Repeating edges against the sky</span>
          </figcaption>
        </figure>
      </div>
    </section>
  </main>

  <footer>
    Himeji Castle, winter and spring.
  </footer>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Close image">&times;</button>
    <div class="lightbox-inner">
      <img id="lightboxImage" src="" alt="" />
      <div class="lightbox-caption" id="lightboxCaption"></div>
    </div>
  </div>

  <script>
    const cards = document.querySelectorAll('.card[data-full]');
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightboxImage');
    const lightboxCaption = document.getElementById('lightboxCaption');
    const lightboxClose = document.getElementById('lightboxClose');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const full = card.getAttribute('data-full');
        const caption = card.getAttribute('data-caption');
        const img = card.querySelector('img');

        lightboxImage.src = full;
        lightboxImage.alt = img.alt || caption || '';
        lightboxCaption.textContent = caption || '';
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
      });
    });

    function closeLightbox() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImage.src = '';
    }

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('open')) {
        closeLightbox();
      }
    });
  </script>
</body>
</html>